{
    "name": "maksim-yurash/ecommerce-suite",
    "description": "Laravel package for an abstract internet shop: models, migrations, CRUD controllers, API, facades, middleware and tests.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maksim Yurash",
            "email": "m.yurash.maks@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MaksimYurash\\EcommerceSuite\\": "src/",
            "MaksimYurash\\EcommerceSuite\\Database\\Factories\\": "database/factories/",
            "MaksimYurash\\EcommerceSuite\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaksimYurash\\EcommerceSuite\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MaksimYurash\\EcommerceSuite\\EcommerceSuiteServiceProvider"
            ],
            "aliases": {
                "CurrencyRate": "MaksimYurash\\EcommerceSuite\\Facades\\CurrencyRate",
                "DeliveryCost": "MaksimYurash\\EcommerceSuite\\Facades\\DeliveryCost"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
